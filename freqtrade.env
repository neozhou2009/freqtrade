# Freqtrade 机器人环境配置
# 基于 config_templates/config.json 配置

# 机器人基本配置
BOT_NAME=freqtrade-standalone
DRY_RUN=true
TRADING_MODE=spot

# 交易所配置
EXCHANGE_NAME=binance
API_KEY=
API_SECRET=

# 交易配置
MAX_OPEN_TRADES=3
STAKE_CURRENCY=USDT
STAKE_AMOUNT=unlimited
TRADABLE_BALANCE_RATIO=0.99

# API 服务器配置
API_ENABLED=true
API_LISTEN_IP=0.0.0.0
API_LISTEN_PORT=8080
API_USERNAME=fq_user1
API_PASSWORD=fq_uer1
JWT_SECRET=cc2c5c7ca3d9d48d9c7420a50c16bbd0555247c0ceee6e1b26ad72d74367c485
WS_TOKEN=2fM5ULjfkOYXDZK9WBly8fVBrdDsboL_zA

# 数据库配置
DB_TYPE=sqlite
DB_URL=sqlite:////freqtrade/user_data/tradesv3.sqlite

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL 配置 (如果使用)
POSTGRES_DB=freqtrade
POSTGRES_USER=freqtrade
POSTGRES_PASSWORD=freqtrade123

# 时区配置
TZ=Asia/Shanghai

# 日志配置
LOG_LEVEL=info
LOG_FILE=/freqtrade/user_data/logs/freqtrade.log
